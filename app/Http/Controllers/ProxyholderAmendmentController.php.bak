    /**
     * Store a newly created resource in storage.
     *
     * @param  \Illuminate\Http\Request  $request
     * @return \Illuminate\Http\Response
     */

    //  done 2023-08-31
    public function store(Request $request)
    {
        try {

            $validator = Validator::make($request->all(), [
                'accountToAssign' => 'required|numeric',
                'assignor' => 'required|numeric',
                'assignee' => 'required|numeric',

            ],);

            if ($validator->fails()) {
                $err = EApp::obj_to_array($validator->errors());
                return response()->json(["message" => $err[array_key_first($err)][0], "field" => array_key_first($err)], 400);
            }


            $accountToAssign = StockholderAccount::findOrFail($request->accountToAssign);
            $assigneeDetails = User::with('nonMemberAccount')->findOrFail($request->assignee);
            $assignor        = $accountToAssign->stockholder->accountType === 'indv' ? $accountToAssign->stockholder->userId : $request->assignor;
            $assignorDetails = User::whereIn('role', ['stockholder', 'corp-rep'])->findOrFail($assignor);


            if ($assigneeDetails->role !== 'non-member') {

                return response()->json(['message' => 'Only the General Manager (GM) can be a proxyholder for the Amendment Proxy.'], 400);
            }

            if ($assigneeDetails->nonMemberAccount->isGM !== 1) {

                return response()->json(['message' => 'Only the General Manager (GM) can be a proxyholder for the Amendment Proxy.'], 400);
            }


            $assignorAccountNo = $assignorDetails->role === 'stockholder'
                ? $assignorDetails->stockholder->accountNo
                : $assignorDetails->stockholderAccount->stockholder->accountNo;








            if ($accountToAssign->stockholder->accountNo !== $assignorAccountNo) {

                Log::error('The assignor and the stock being assigned have different account numbers.');

                return response()->json(['message' => 'The assignor and the stock being assigned have different account numbers.'], 400);
            }


            if ($assignorDetails->role ===  'corp-rep') {

                if ($assignorDetails->email === null) {
                    return response()->json(['message' => 'Proxy cannot be assigned. The assignor doesn\'t have an email address.'], 400);
                }

                if ($assignorDetails->email != $accountToAssign->user->email) {
                    return response()->json(['message' => 'Proxy cannot be assigned.'], 400);
                }
            }

            DB::beginTransaction();



            $insertProxy = new ProxyAmendment([
                'proxyAmendmentFormNo' => $accountToAssign->accountKey,
                'accountId' => $request->accountToAssign,
                'assignorId' => $assignor,
                'assigneeId' => $request->assignee,
                'createdBy' => Auth::user()->id
            ]);

            if (!$insertProxy->save()) {

                return response()->json(['message' => "An error was encountered while inserting the record."], 500);
            }

            ActivityController::log(['activityCode' => '00099', 'remarks' => "Assigned an amendment proxy with reference no A-" . $accountToAssign->accountKey, 'proxyAmendmentId' => $insertProxy->proxyAmendmentId]);


            DB::commit();

            return response()->json(['message' => 'The proxy for amendment has been successfully assigned'], 200);
        } catch (Exception $e) {

            Log::error($e);

            return response()->json([], 500);
        }
    }

