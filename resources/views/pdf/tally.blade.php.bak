                    <tbody>

                      <?php 


                        $candidateTotal = [];
                        $overAllTotal = 0;

                        foreach($processBallot as $ballot) {

                          $role     = $ballot['accountType'] === 'indv' ? 'Stockholder' : $ballot['role'];
                          $revoked  = $ballot['revoked'] === 1 ? '<span class="badge badge-secondary">Revoked</span>' : '';
                          $status   = $ballot['status'] === 1 ? '<span class="badge badge-success">Submitted</span>' : '<span class="badge badge-danger">Unsubmitted</span>'; 
                          $ballotNo = $ballot['status'] === 1 ? '<span class="font-weight-bold text-primary ballot-no">'.$ballot['ballotNo'].'</span>' : '<span class="font-weight-bold">'.$ballot['ballotNo'].'</span>';

                          $votesAvailable = $ballot['votesAvailable'] * 3;
                        
                          $votesUnused = ($ballot['votesAvailable'] * 3) - $ballot['votesUsed'];

                          $votesUnused = $ballot['status'] === 1 ?  ($votesUnused === 0 ? '' : $votesUnused) : '';

                          echo '<tr data-id="'.$ballot['id'].'">
                                  <td class="td-padding">'.strtoupper($ballot['ballotType']).'</td>
                                  <td class="td-padding">'.$ballotNo.'</td>
                                  <td class="td-padding text-center">'.$revoked.'</td>
                                  <td class="td-padding">'.$votesUnused.'</td>
                                  <td class="td-padding text-center">'.$status.'</td>';


                          $ballotTotalVote = 0;

                          foreach($candidates as $candidate) {

                            $matched = false;

                            foreach($candidateVotes as $candidateVote) {


                              if($ballot['id'] === $candidateVote['ballotId'] AND $candidate->candidateId === $candidateVote['candidateId']) {

                                $matched = true;

                                $vote = $candidateVote['vote'];


                                $ballotTotalVote = $ballotTotalVote + $vote;

                                $candidateTotal[$candidate->candidateId][] = $vote;


                              }


                              
                    

                            }

                            echo $matched === true ? '<td class="td-padding text-center table-light">' . $vote . '</td>' : '<td class="td-padding text-center table-light"></td>';
                            

                            

                          } 


                          $overAllTotal = $overAllTotal + $ballotTotalVote;


                          echo '<td class="td-padding text-center">'.($ballotTotalVote === 0 ? '-' : $ballotTotalVote).'</td>';

                          echo '</tr>';
                        }

                      ?>
